import tensorflow as tf
from tensorflow.keras.models import load_model
import pandas as pd
import numpy as np
import cv2
import os
from google.colab import drive

# --- 1. เชื่อมต่อ Google Drive ---
if not os.path.exists('/content/drive'):
    drive.mount('/content/drive')

BASE_SAVE_PATH = '/content/drive/MyDrive/Colab_Notebooks/Contest_food5/'
# แก้ชื่อไฟล์ให้ตรงกับที่เทรนล่าสุด
MODEL_PATH = os.path.join(BASE_SAVE_PATH, 'best_food_rankerv3.keras')
IMG_DIR = os.path.join(BASE_SAVE_PATH, 'Test Set Samples/Test Images/')
# ต้องเป็น 128 เท่านั้นตามที่เทรนไว้
IM_SIZE = (128, 128)

# --- 2. โหลดโมเดล ---
if os.path.exists(MODEL_PATH):
    model = load_model(MODEL_PATH)
    print(f"โหลดโมเดล '{os.path.basename(MODEL_PATH)}' สำเร็จ!")
else:
    print(f" ไม่พบไฟล์โมเดลที่: {MODEL_PATH}")

# --- 3. เตรียมไฟล์ภาพ ---
all_images = sorted([f for f in os.listdir(IMG_DIR) if f.lower().endswith(('.jpg', '.jpeg', '.png'))])
print(f"พบรูปภาพทั้งหมด {len(all_images)} รูป")

def prepare_img(path):
    img = cv2.imread(path)
    if img is None: return None
    img = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)
    img = cv2.resize(img, IM_SIZE, interpolation=cv2.INTER_AREA)
    return np.expand_dims(img / 255.0, axis=0).astype(np.float32)

# --- 4. เริ่มทำนายผล (แก้ไข Logic ผู้ชนะให้ตรง
results = []
for i in range(0, len(all_images) - 1, 2):
    img1_name = all_images[i]
    img2_name = all_images[i+1]

    i1 = prepare_img(os.path.join(IMG_DIR, img1_name))
    i2 = prepare_img(os.path.join(IMG_DIR, img2_name))

    if i1 is not None and i2 is not None:
        prob = model.predict([i1, i2], verbose=0)[0][0]

        # --- แก้ไขจุดนี้ ---
        # เปลี่ยนจาก winner_label = 2 เป็น 1 เมื่อค่า prob เกิน 0.5
        if prob > 0.5:
            winner_label = 1  
            confidence = prob
        else:
            winner_label = 2  
            confidence = 1 - prob
        # -----------------

        results.append({
            'Image_A': img1_name,
            'Image_B': img2_name,
            'Winner': winner_label,
            'Confidence': f"{confidence:.2%}"
        })

# --- 5. บันทึกผล ---
df_results = pd.DataFrame(results)
OUTPUT_FILE = os.path.join(BASE_SAVE_PATH, 'auto_match_final_results.csv')
df_results.to_csv(OUTPUT_FILE, index=False)

print("-" * 30)
print(f" ประมวลผลเสร็จสิ้น {len(results)} คู่")
print(f" บันทึกผลที่: {OUTPUT_FILE}")
display(df_results.head())
